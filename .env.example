# ==============================================================================
# Environment Variables Template
# ==============================================================================
# This template lists all environment variables required for both local development
# and production environments across all development phases of Clerkey.
# Copy this file to '.env' at the repository root and fill in your actual credentials.
# DO NOT commit real secrets to the repository!
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Core Platform & Database Configurations
# ------------------------------------------------------------------------------

# Database URL used by /apps/backend. 
# Defaults to local Postgres container configured in docker-compose.yml.
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
# For production (Alibaba Cloud), point this at your ApsaraDB for PostgreSQL instance.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/clerkey

# Secret key used for signing JWT tokens in self-built authentication.
# Generate a secure string (e.g., using 'openssl rand -hex 32') for production.
JWT_SECRET=super-secret-key-for-dev-use-secure-random-in-production

# ------------------------------------------------------------------------------
# 2. AI Reasoning Model Configurations
# ------------------------------------------------------------------------------

# API Key for Qwen Cloud (Alibaba's flagship AI reasoning model family).
# Required by /apps/backend to orchestrate reasoning loops, confidence scores,
# and customer response generation.
QWEN_API_KEY=your_qwen_cloud_api_key_here

# ------------------------------------------------------------------------------
# 3. Messaging Channel Connections (adapters)
# ------------------------------------------------------------------------------

# WhatsApp Business Cloud API Access Token.
# Required by the WhatsApp channel adapter to ingest customer inquiries 
# and push proactive check-ins/escalations.
WHATSAPP_API_TOKEN=your_whatsapp_business_cloud_api_token_here

# Email Gateway / IMAP / SMTP API credentials.
# Required by the Email channel adapter to retrieve customer inquiries 
# and dispatch auto-replies or escalation notifications.
# Can be structured as JSON containing server host, port, user, and app-specific password.
EMAIL_API_CREDENTIALS={"host":"smtp.gmail.com","port":587,"username":"support@yourbusiness.com","password":"app_specific_password_here"}

# ------------------------------------------------------------------------------
# 4. Infrastructure & Alibaba Cloud Deployment Configurations
# ------------------------------------------------------------------------------

# Access Key ID for Alibaba Cloud Resource Access Management (RAM).
# Required by deployment scripts or infra setup toolchains to manage compute,
# DB migrations, and deploy Cloud Function Compute packages.
ALIBABA_ACCESS_KEY=your_alibaba_cloud_ram_access_key_id_here

# Secret Key corresponding to the RAM Access Key.
# Required by deployment scripts to authenticate Alibaba Cloud CLI / API calls.
ALIBABA_SECRET_KEY=your_alibaba_cloud_ram_secret_key_here
